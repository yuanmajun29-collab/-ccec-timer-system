{
  "name": "edgebox-gate",
  "role": "CCEC edge entrypoint",
  "version": 2,
  "routes": {
    "stationScreen": "/?station=A601",
    "adminConsole": "/admin/",
    "adminLogin": "/admin/login.html",
    "restApi": "/api/",
    "webSocket": "/ws/station/{stationCode}",
    "health": "/healthz",
    "backendHealth": "/actuator/health"
  },
  "upstreams": {
    "timerBackend": "timer-backend:8080"
  },
  "tls": {
    "productionConfig": "ccec-timer-https.conf",
    "certificate": "/etc/nginx/certs/tls.crt",
    "certificateKey": "/etc/nginx/certs/tls.key"
  }
}
