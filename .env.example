# CCEC Timer System — 部署环境变量
# 首次搭建：./deploy/scripts/setup-local.sh  或  make setup
# 文档：docs/run-and-deploy.md

HTTP_PORT=80
BACKEND_PORT=8080
REDIS_PORT=6379
ORACLE_PORT=1521

ORACLE_SYS_PASSWORD=Oracle_123
ORACLE_APP_USER=CCEC_TIMER
ORACLE_APP_PASSWORD=CCEC_TIMER_123

PLC_HOST=128.10.40.10
PLC_RACK=0
PLC_SLOT=1
POLL_INTERVAL_MS=500
REDIS_STREAM_KEY=station:event:queue
TIMER_REDIS_STREAM_KEY=station:event:queue

# 生产首次部署且库中无用户时，可设为 true 以写入默认管理员（务必上线后立即改密并改回 false）
TIMER_SECURITY_DEFAULT_ADMIN_ENABLED=false

# MQTT（安卓原生终端 / Mosquitto）
MQTT_PORT=1883
TIMER_MQTT_ENABLED=true
TIMER_MQTT_BROKER_URI=tcp://mosquitto:1883
TIMER_MQTT_TOPIC_PREFIX=ccec/station


# ===== Production / Observability =====
COMPOSE_PROJECT_NAME=ccec-timer-system
PUBLIC_HOST=localhost
HTTP_PORT=80
HTTPS_PORT=443

# Grafana / Prometheus
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=ChangeMe_Grafana_123
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093
LOKI_PORT=3100

# Alertmanager SMTP
SMTP_SMARTHOST=smtp.example.com:587
SMTP_FROM=ccec-timer@example.com
SMTP_AUTH_USERNAME=ccec-timer@example.com
SMTP_AUTH_PASSWORD=ChangeMe_SMTP
ALERT_EMAIL_TO=ops@example.com

# Backup
BACKUP_RETENTION_DAYS=14
BACKUP_DIR=/opt/ccec-timer/backups

# Image registry for CI/CD
REGISTRY=ghcr.io
IMAGE_NAMESPACE=yuanmajun29-collab/ccec-timer-system
IMAGE_TAG=latest
